{
  "expo": {
    "name": "MP MARKET",
    "slug": "mpmarket",
    "version": "2.0.0",
    "description": "MP MARKET - India's Trusted Marketplace for Buying & Selling by Evolucentsphere Pvt Ltd",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mpmarket",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#002F34"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.evolucentsphere.mpmarketing",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Upload product photos"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#002F34"
      },
      "package": "com.evolucentsphere.mpmarketing",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d8845a67-9286-4c64-be63-24ec4c6076ea"
      }
    }
  }
}
