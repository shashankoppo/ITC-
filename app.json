{
  "expo": {
    "name": "mpmarketing",
    "slug": "mpmarketing",
    "version": "2.0.0",
    "description": "mpmarketing - India's Trusted Marketplace for Buying & Selling by Evolucentsphere Pvt Ltd",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mpmarketing",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#002F34"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.evolucentsphere.mpmarketing",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Upload product photos"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#002F34"
      },
      "package": "com.evolucentsphere.mpmarketing",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "backgroundColor": "#ffffff"
    },
    "plugins": ["expo-router", "expo-font", "expo-web-browser"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
